# Slip — all optional. The app derives URLs from the runtime origin; nothing is hardcoded.
# Copy to .env.local to override.

# Absolute site URL (only for Open-Graph image resolution). On Vercel, VERCEL_URL is used
# automatically if this is unset.
# NEXT_PUBLIC_SITE_URL=https://your-slip-domain

# The opt-in "Server" phoneme backend for weak devices. Until this is set, choosing
# "Server" in settings degrades honestly to the on-device model. See services/infer.
# NEXT_PUBLIC_PHONEME_SERVER_URL=https://your-infer-host

# Default everyone to the server seam instead of just offering it (needs the URL above).
# NEXT_PUBLIC_PHONEME_BACKEND=server
